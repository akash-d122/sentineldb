{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Bash(uv run pytest*)",
      "Bash(uv run ruff*)",
      "Bash(git status*)",
      "Bash(git diff*)"
    ],
    "ask": [
      "Bash(uv add*)",
      "Bash(git add*)",
      "Bash(git commit*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(**/.env)",
      "Bash(rm -rf*)",
      "Bash(git push*)",
      "Bash(ssh*)",
      "Bash(mysql*)",
      "Bash(psql*)",
      "Bash(aws*)"
    ]
  },
  "autoCompactEnabled": true
}
